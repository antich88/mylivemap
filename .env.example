# Flask
FLASK_ENV=development

# Storage mode (optional override): local | sqlalchemy
# APP_MODE=local

# Database (override on Render via DATABASE_URL from managed Postgres)
DATABASE_URL=sqlite:///database.db

# Secret keys / tokens
# In production на Render секреты задаются через ENV, так что не храните их в репозитории
LIVE_MAP_DB_KEY=dev-live-map-key
SECRET_KEY=dev-secret-key-change-me
# Cloudinary (оставьте пустым для отключения удалённого хранения аватаров)
# Пример полного набора: CLOUDINARY_API_KEY=<your_key> CLOUDINARY_API_SECRET=<your_secret> CLOUDINARY_CLOUD_NAME=<your_cloud>
# либо как раньше: CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_CLOUD_NAME=<your_cloud_name>
CLOUDINARY_API_KEY=<your_api_key>
CLOUDINARY_API_SECRET=<your_api_secret>
# Опционально задайте каталог и префикс хранения для генерации путей в профиле.
# CLOUDINARY_AVATAR_FOLDER=live_map/avatars
